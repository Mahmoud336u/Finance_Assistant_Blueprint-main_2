{
  "annotations": {
    "list": []
  },
  "description": "Meridian API — Key Performance Indicators",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{service=\"meridian-api\"}[5m])",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{service=\"meridian-api\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{service=\"meridian-api\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{service=\"meridian-api\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "LLM Token Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(meridian_llm_tokens_total{type=\"prompt\"}[5m])",
          "legendFormat": "Prompt Tokens/s"
        },
        {
          "expr": "rate(meridian_llm_tokens_total{type=\"completion\"}[5m])",
          "legendFormat": "Completion Tokens/s"
        }
      ]
    },
    {
      "title": "LLM Cost (Cents/min)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(meridian_llm_cost_cents_total[5m]) * 60",
          "legendFormat": "Cost ¢/min"
        }
      ]
    },
    {
      "title": "LLM Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(meridian_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 Bedrock Latency"
        }
      ]
    },
    {
      "title": "RAG Chunks Retrieved (Distribution)",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "meridian_rag_chunks_retrieved_bucket",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\", service=\"meridian-api\"}[5m])",
          "legendFormat": "5xx Errors/s"
        },
        {
          "expr": "rate(http_requests_total{status=~\"4..\", service=\"meridian-api\"}[5m])",
          "legendFormat": "4xx Errors/s"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["meridian", "api", "llm"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Meridian API Dashboard",
  "uid": "meridian-api-main"
}
