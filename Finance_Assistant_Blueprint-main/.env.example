# ============================================================
# Meridian — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=meridian
ENVIRONMENT=dev                          # dev | staging | prod
LOG_LEVEL=DEBUG                          # DEBUG | INFO | WARNING | ERROR
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                            # Set to CPU count in prod
ALLOWED_ORIGINS=http://localhost:3000     # Comma-separated CORS origins

# --- Database (Aurora PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://meridian:changeme@localhost:5432/meridian
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false                      # Set true to log SQL in dev

# --- Redis (ElastiCache) ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                       # Leave blank to use IAM role / instance profile
AWS_SECRET_ACCESS_KEY=

# --- AWS Bedrock (AI/LLM) ---
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- AWS Cognito (Auth) ---
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=meridian-api
ENABLE_METRICS=true
ENABLE_TRACING=true

# --- Feature Flags ---
AI_CHAT_ENABLED=true
SEMANTIC_CACHE_ENABLED=false
